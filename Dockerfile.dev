# Development / test sandbox image for the frontend (and the test-runner).
#
# Purpose (INFRA-001): execute all untrusted dependency code — npm install,
# the Vite dev server, vitest, vue-tsc — inside a container that has NO access
# to the host home directory or SSH keys. The host is used only for editing
# files and running git.
#
# Node version matches package.json engines (^20.19 || >=22.12).
FROM node:22-bookworm-slim

# Tini for clean signal handling (Ctrl-C stops the dev server cleanly).
# git is needed by the containerized pre-commit hooks (gitleaks staged scan +
# lint-staged read the git index). ca-certificates lets the one-time gitleaks
# binary download (below) verify TLS during the image build.
RUN apt-get update \
  && apt-get install -y --no-install-recommends tini git ca-certificates curl \
  && rm -rf /var/lib/apt/lists/*

# The base image ships a non-root `node` user (uid/gid 1000). Run as that user
# so nothing in the container runs as root, and so a malicious postinstall
# cannot trivially escalate.
ENV NODE_ENV=development
WORKDIR /app

# We deliberately do NOT copy source or run `npm install` at build time.
# Source is bind-mounted and dependencies are installed at runtime into a
# named volume (see docker-compose.yml). This keeps the image generic and
# ensures node_modules never round-trips through the host filesystem.
#
# npm hardening (INFRA-002): .npmrc sets ignore-scripts=true, so NO dependency
# lifecycle scripts run on install. Native deps that genuinely need a build are
# ALLOW-LISTED and rebuilt explicitly. Current allowlist:
#   - sharp  (image processing, used by scripts/generate-pwa-icons.mjs)
# The rebuild runs in the `install` compose service (`npm rebuild sharp`),
# where deps are installed into the volume. Add to that command if a new native
# dependency is introduced.

# Pre-create the volume mountpoints owned by the non-root `node` user. Docker
# named volumes inherit the ownership of their mountpoint in the image, so this
# makes the node_modules volumes (frontend + server) and the npm cache writable
# by `node` (npm runs as non-root). Without this, a fresh named volume mounts
# root-owned and `npm ci` fails with EACCES.
RUN mkdir -p /app/node_modules /app/server/node_modules /home/node/.npm \
  && chown -R node:node /app /home/node/.npm

# Drop to the unprivileged user for everything that follows.
USER node

# Bake the gitleaks binary into the image with a single, controlled fetch at
# BUILD time, so the network-isolated `hooks` service can run the secret scan
# OFFLINE at commit time. The scanner caches under ~/.gitleaks-cache.
# Pinned to the same version the project's CI/pre-commit already used (8.27.2).
RUN GITLEAKS_VERSION=8.27.2; \
    arch="$(uname -m)"; \
    case "$arch" in \
      x86_64) gl_arch=x64 ;; \
      aarch64|arm64) gl_arch=arm64 ;; \
      *) gl_arch="$arch" ;; \
    esac; \
    url="https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_${gl_arch}.tar.gz"; \
    dest="$HOME/.gitleaks-cache/v${GITLEAKS_VERSION}"; \
    mkdir -p "$dest"; \
    (curl -fsSL "$url" | tar -xz -C "$dest" gitleaks) \
      && chmod +x "$dest/gitleaks" \
      && "$dest/gitleaks" version \
      || echo "WARN: gitleaks prefetch failed; hooks service will need network on first run";

ENTRYPOINT ["/usr/bin/tini", "--"]
# Default command is overridden per-service in docker-compose.yml.
CMD ["node", "--version"]
