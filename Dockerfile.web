# Production image for the static PWA (the `web` Railway service — INFRA-007).
# Builds the Vite app and serves dist/ with a tiny static server.

# ---- build stage ----------------------------------------------------------
FROM node:22-bookworm-slim AS build
WORKDIR /app

# Install deps with --ignore-scripts (matches the .npmrc hardening; .npmrc is
# excluded from build contexts by .dockerignore for safety). Rebuild sharp for
# the PWA icon pipeline.
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts && npm rebuild sharp

# Bring in the source needed for the build.
COPY . .
RUN npm run build

# ---- runtime stage --------------------------------------------------------
FROM node:22-bookworm-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app

# `serve` is a small static file server with SPA fallback.
RUN npm install -g serve@14.2.4

COPY --from=build /app/dist ./dist

# Railway injects PORT; serve binds it. -s = single-page-app fallback.
EXPOSE 3000
CMD ["sh", "-c", "serve -s dist -l ${PORT:-3000}"]
