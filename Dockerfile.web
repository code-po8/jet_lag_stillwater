# Production image for the static PWA (the `web` Railway service — INFRA-007).
# Builds the Vite app and serves dist/ with a tiny static server.

# ---- build stage ----------------------------------------------------------
FROM node:22-bookworm-slim AS build
WORKDIR /app

# Install deps with --ignore-scripts (matches the .npmrc hardening; .npmrc is
# excluded from build contexts by .dockerignore for safety). Rebuild sharp for
# the PWA icon pipeline.
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts && npm rebuild sharp

# Bring in the source needed for the build.
COPY . .

# API base URL for the client, inlined at BUILD time by Vite (import.meta.env).
# Railway passes it as a --build-arg; it must be exported to the environment
# BEFORE `npm run build` or the bundle ships with an empty base and the client
# POSTs room requests same-origin (to this static server) → 405. Set the
# `VITE_API_URL` build variable on the Railway `web` service to the `api` URL.
ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL}
RUN npm run build

# ---- runtime stage --------------------------------------------------------
FROM node:22-bookworm-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app

# `serve` is a small static file server with SPA fallback.
RUN npm install -g serve@14.2.4

COPY --from=build /app/dist ./dist

# Railway injects PORT; serve binds it. -s = single-page-app fallback.
EXPOSE 3000
CMD ["sh", "-c", "serve -s dist -l ${PORT:-3000}"]
