{
  "name": "jet-lag-stillwater-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Realtime sync backend (Fastify + WebSocket + Postgres) for Jet Lag Stillwater",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "fastify": "5.2.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
