# npm hardening (INFRA-002) — defense-in-depth against supply-chain attacks.
#
# ignore-scripts: do NOT run package lifecycle scripts (preinstall/install/
#   postinstall/prepare) on install. This blocks the single most common
#   npm attack vector — a malicious dependency executing code during install.
#   Trade-offs handled elsewhere:
#     - husky's `prepare` no longer auto-runs; run `npm run prepare` once after
#       install to set up git hooks (see DEVELOPMENT.md).
#     - native deps that need a build step (e.g. sharp) are rebuilt explicitly
#       and allow-listed (see Dockerfile.dev / the icon-generation workflow).
ignore-scripts=true

# save-exact: pin exact versions when adding deps (no ^ / ~ ranges), so a
#   compromised patch release can't be pulled in silently on the next install.
save-exact=true

# engine-strict: fail install if the Node/npm version doesn't satisfy the
#   "engines" field, keeping everyone on a known-good toolchain.
engine-strict=true
